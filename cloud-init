#cloud-config

# 1. User Configuration
system_info:
  default_user:
    name: nutanix

users:
  - name: nutanix
    groups: wheel
    sudo: ALL=(ALL) ALL
    shell: /bin/bash
    lock_passwd: false

chpasswd:
  list: |
    nutanix:nutanix/4u
  expire: false

# 2. Pre-Provisioning Warnings & Cgroup Config
write_files:
  - path: /etc/issue
    content: |
      
      =========================================================
      ⚠️  SYSTEM IS CURRENTLY PROVISIONING - DO NOT LOG IN  ⚠️
      The system will automatically reboot when finished.
      =========================================================
      
      \S
      Kernel \r on an \m

  - path: /etc/nologin
    content: |
      System is currently provisioning packages and configuring the kernel.
      Please wait for the automatic reboot to complete.

  - path: /etc/systemd/system/user@.service.d/delegate.conf
    owner: root:root
    permissions: '0644'
    content: |
      [Service]
      Delegate=yes

  # Overwrite sshd_config entirely — the CIS image ships it as a single
  # line (PasswordAuthentication no) with no Include directive, so drop-ins
  # in sshd_config.d/ are never read. Our directives go BEFORE the Include
  # so they win (sshd first-match-wins rule).
  - path: /etc/ssh/sshd_config
    owner: root:root
    permissions: '0600'
    content: |
      PasswordAuthentication yes
      UsePAM yes
      Include /etc/ssh/sshd_config.d/*.conf

# 3. Package Management
package_update: true
package_upgrade: true

packages:
  - podman

# 4. Fixups, then cleanup before reboot
runcmd:
  # Swap out the NKP authselect profile for the standard sssd one
  - authselect select sssd with-faillock --force

  # Ensure nullok is present in PAM (idempotent)
  - sed -i '/pam_unix.so/{ /nullok/! s/$/ nullok/ }' /etc/pam.d/password-auth /etc/pam.d/system-auth

  # Fix shadow ownership and permissions (CIS image ships it as 744 root:root)
  - chown root:shadow /etc/shadow
  - chmod 000 /etc/shadow

  # Validate sshd config and reload
  - sshd -t && systemctl restart sshd

  # Restore normal issue and remove nologin
  - echo -e '\S\nKernel \r on an \m\n' > /etc/issue
  - rm -f /etc/nologin

# 5. Trigger Reboot After Provisioning
power_state:
  mode: reboot
  message: "Cloud-init provisioning complete. Rebooting to apply cgroup and kernel updates."
  timeout: 15
  condition: True
